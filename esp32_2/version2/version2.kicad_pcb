	(gr_text "add in GND near the vias\nbecause if something changes and the pcb\nneeds to find ground, the current will\nspread throughout the entire pcb and \ncan cause serious damage. better to have\na GND pin right there in case something\nhappens"
		(at 92.69 58.84 0)
		(layer "Cmts.User")
		(uuid "7fd2e4c0-37aa-48d7-801f-d7abd9d9362b")
		(effects
